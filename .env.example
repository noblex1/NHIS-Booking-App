NODE_ENV=development
PORT=5000

# Frontend URL (for CORS)
# Local testing: http://localhost:5173
# Production: https://your-frontend-url.vercel.app
CLIENT_URL=http://localhost:5173

MONGODB_URI=mongodb://127.0.0.1:27017/nhis_booking

JWT_SECRET=replace-with-a-very-strong-secret
JWT_EXPIRES_IN=7d

OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5

# Email Configuration
# Option 1: Brevo (Recommended for Production)
# Sign up at: https://app.brevo.com (Free: 300 emails/day)
# Get API key: https://app.brevo.com/settings/keys/api
# Verify sender: https://app.brevo.com/senders
BREVO_API_KEY=your-brevo-api-key-here
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=NHIS Appointment System

# Option 2: SMTP (Fallback for Local Development)
# Only used if BREVO_API_KEY is not set
# For Gmail: Use smtp.gmail.com with App Password
# For Outlook: Use smtp-mail.outlook.com
# For Yahoo: Use smtp.mail.yahoo.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
